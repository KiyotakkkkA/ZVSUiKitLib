{
    "name": "@kiyotakkkka/zvs-uikit-lib",
    "description": "React UI kit with Tailwind CSS components and hooks",
    "keywords": [
        "react",
        "ui-kit",
        "component-library",
        "typescript",
        "tailwind",
        "vite",
        "recharts",
        "code-highlighting"
    ],
    "author": "KiyotakkkkA",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/KiyotakkkkA/ZVSUiKitLib.git",
        "directory": "package"
    },
    "private": false,
    "version": "5.0.0",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "**/*.css"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./server": {
            "types": "./dist/server.d.ts",
            "import": "./dist/server.js",
            "default": "./dist/server.js"
        },
        "./styles.css": "./dist/zvs-uikit-lib.css"
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@iconify/react": "^6.0.2",
        "@tanstack/react-virtual": "^3.13.23",
        "clsx": "^2.1.1",
        "recharts": "^3.8.1",
        "shiki": "^4.0.2",
        "tailwind-merge": "^3.5.0"
    },
    "peerDependencies": {
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwindcss": "^4",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1"
    },
    "overrides": {
        "vite": "^7.3.1"
    }
}
