{
    "name": "@kiyotakkkka/zvs-uikit-lib",
    "author": "KiyotakkkkA",
    "repository": {
        "type": "git",
        "url": "https://github.com/KiyotakkkkA/ZVSUiKitLib.git"
    },
    "private": false,
    "version": "2.0.5",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./ui": {
            "types": "./dist/ui/index.d.ts",
            "import": "./dist/ui.js",
            "default": "./dist/ui.js"
        },
        "./hooks": {
            "types": "./dist/hooks/index.d.ts",
            "import": "./dist/hooks.js",
            "default": "./dist/hooks.js"
        },
        "./providers": {
            "types": "./dist/providers/index.d.ts",
            "import": "./dist/providers.js",
            "default": "./dist/providers.js"
        },
        "./styles.css": "./dist/zvs-uikit-lib.css"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "dev": "vite",
        "build": "vite build && npm run build:types",
        "build:types": "tsc -p tsconfig.build.json",
        "lint": "eslint .",
        "preview": "vite preview"
    },
    "dependencies": {
        "@iconify/react": "^6.0.2",
        "@tanstack/react-virtual": "^3.13.23",
        "clsx": "^2.1.1",
        "tailwind-merge": "^3.5.0"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.7",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.1",
        "eslint": "^9.39.1",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.4.24",
        "globals": "^16.5.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwindcss": "^4",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.48.0",
        "vite": "^7.3.1"
    },
    "overrides": {
        "vite": "^7.3.1"
    }
}
